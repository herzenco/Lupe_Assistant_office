SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
JWT_SECRET=generate-with-openssl-rand-hex-32
LOGIN_PIN=123456
# LOGIN_PASSWORD is still accepted as a temporary fallback during migration.
DASHBOARD_API_KEY=generate-with-openssl-rand-hex-32
MONTHLY_BUDGET_USD=150
LUPE_DASHBOARD_URL=http://localhost:3000
# Comma-separated directories that Content Asset Bridge may register from.
CONTENT_ASSET_BASE_DIRS=/Users/lupe/Library/CloudStorage/GoogleDrive-lupe@herzenco.co
# Publicly reachable base URL for temporary Instagram media URLs.
CONTENT_ASSET_PUBLIC_BASE_URL=https://your-dashboard-public-url.example
LUPE_DASHBOARD_KEY=match-your-dashboard-api-key
LUPE_MODEL=your-current-agent-model
LUPE_MACHINE_ID=lupe-main-machine
LUPE_AGENT_NAME=Lupe
LUPE_HEALTH_MACHINE_ID=lupe-main-machine
LUPE_GOOGLE_DRIVE_PATH=/Users/lupe/Library/CloudStorage/GoogleDrive-lupe@herzenco.co
