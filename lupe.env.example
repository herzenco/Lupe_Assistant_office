# Copy this file to lupe.env on Lupe's machine and fill in the key.
# Do not commit lupe.env.

LUPE_MACHINE_ID=lupe-main-machine
LUPE_AGENT_NAME=Lupe
LUPE_DASHBOARD_URL=https://lupe-assistant-office.vercel.app
LUPE_DASHBOARD_KEY=paste-dashboard-api-key-here
LUPE_MODEL=openclaw

# Optional: set this if Google Drive lives at a specific path on Lupe's machine.
# LUPE_GOOGLE_DRIVE_PATH=$HOME/Library/CloudStorage/GoogleDrive-lupe@herzenco.co
